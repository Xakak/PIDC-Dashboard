# backend/.env — copy this to .env and fill in your values
# NEVER commit .env to git

# Same URL as the frontend
SUPABASE_URL=https://your-project-id.supabase.co

# This is the SERVICE ROLE key (NOT the anon key).
# Find it at: Supabase Dashboard → Settings → API → service_role (secret)
# This key bypasses RLS — keep it private, server-side only.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# URL of your Next.js frontend (for CORS)
FRONTEND_URL=http://localhost:3000
